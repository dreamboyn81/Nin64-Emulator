<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <!-- Compact header: title + buttons + folder info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/hero_title"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/hero_subtitle"
            android:textColor="@color/ink_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/pickFolderButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/action"
                android:text="@string/pick_games_folder"
                android:textColor="@android:color/white" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/refreshGamesButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/action_alt"
                android:text="@string/refresh_games"
                android:textColor="@color/ink" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/initButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/action"
                android:text="@string/init_native"
                android:textColor="@android:color/white" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/smokeTestButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/action_alt"
                android:text="@string/run_smoke_test"
                android:textColor="@color/ink" />
        </LinearLayout>

        <TextView
            android:id="@+id/romFolderText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ink_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/gamesHeaderText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/games_header"
            android:textColor="@color/ink"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Game list — primary content, takes all remaining vertical space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/panel">

        <ListView
            android:id="@+id/romListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:fastScrollEnabled="true" />

        <TextView
            android:id="@+id/emptyRomListText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/no_games_placeholder"
            android:textColor="@color/ink_muted"
            android:textSize="14sp" />
    </FrameLayout>

    <!-- Compact bottom panel: status + preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/panel"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:maxLines="3"
            android:minLines="2"
            android:padding="10dp"
            android:text="@string/initial_status"
            android:textColor="@color/ink"
            android:textIsSelectable="true"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/framePreviewImage"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="6dp"
            android:adjustViewBounds="true"
            android:alpha="0.2"
            android:background="@color/panel"
            android:contentDescription="@string/frame_preview_label"
            android:padding="4dp"
            android:scaleType="fitCenter" />

        <!-- Hidden views kept for code compatibility -->
        <TextView
            android:id="@+id/configPathText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/ink"
            android:textIsSelectable="true"
            android:textSize="10sp"
            android:visibility="gone" />

        <TextView android:id="@+id/framePreviewLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/frame_preview_label"
            android:visibility="gone" />

        <TextView android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_label"
            android:visibility="gone" />

        <TextView android:id="@+id/configPathLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/config_path_label"
            android:visibility="gone" />

        <TextView android:id="@+id/romFolderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/rom_folder_label"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
